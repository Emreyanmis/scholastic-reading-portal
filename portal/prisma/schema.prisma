// Reading Portal data model
//
// Design notes:
// - A single "User" table holds both teachers and students (differentiated by `role`).
//   For a real product I'd split into separate tables once role-specific fields appear,
//   but for this scope a single table keeps joins simple.
// - "Assignment" represents (book, student, due date) and tracks status + minutes.
//   Teacher is denormalized onto Assignment so teachers can quickly query their own.
// - "ReadingSession" is an append-only log of minutes-read events. The current
//   Assignment.minutesRead is a materialized sum we update on each log so the
//   teacher dashboard can render without aggregation. This is the smallest change
//   that lets us evolve to per-session reporting later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite is used for the demo (zero-config, embeddable). The schema is
  // intentionally portable to Postgres — switching just requires changing
  // `provider` and the DATABASE_URL.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite doesn't support Prisma `enum`s, so role + status are stored as
// strings. We constrain them in app code via TypeScript unions + Zod schemas.
// On Postgres this would be a real enum.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   // "TEACHER" | "STUDENT" — stored as string for SQLite portability
  createdAt    DateTime @default(now())

  // Teacher-side
  assignmentsCreated Assignment[] @relation("AssignmentTeacher")
  // Student-side
  assignmentsReceived Assignment[] @relation("AssignmentStudent")
}

model Book {
  id          String   @id @default(cuid())
  title       String
  author      String
  coverColor  String   @default("#fee2e2") // simple placeholder “cover”
  summary     String
  content     String   // body text shown in the in-app reader
  gradeLevel  String?
  createdAt   DateTime @default(now())

  assignments Assignment[]
}

model Assignment {
  id          String           @id @default(cuid())
  bookId      String
  book        Book             @relation(fields: [bookId], references: [id])
  teacherId   String
  teacher     User             @relation("AssignmentTeacher", fields: [teacherId], references: [id])
  studentId   String
  student     User             @relation("AssignmentStudent", fields: [studentId], references: [id])

  dueDate     DateTime
  status      String           @default("NOT_STARTED") // AssignmentStatus enum
  minutesRead Int              @default(0)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  completedAt DateTime?

  sessions    ReadingSession[]

  @@index([teacherId])
  @@index([studentId])
}

model ReadingSession {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  minutes      Int
  createdAt    DateTime   @default(now())

  @@index([assignmentId])
}
