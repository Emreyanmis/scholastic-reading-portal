# Postgres connection string. For deploys, copy this from your Neon project:
#   https://neon.tech  ->  Project  ->  Connection Details  ->  Pooled connection
#
# For local dev against Neon, set ?sslmode=require (Neon already returns this).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Long random string. In bash: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"
