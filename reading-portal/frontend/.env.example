# Used by the Vite dev server proxy. Defaults to http://localhost:8081.
VITE_DEV_BACKEND=http://localhost:8081

# In production builds, set this to the deployed backend URL (no trailing slash).
# Example: https://reading-portal-backend.onrender.com
# Also set PORTAL_CORS_ORIGINS on Render to your Vercel URL. Leave blank in dev.
VITE_API_BASE=
