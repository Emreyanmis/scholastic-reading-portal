# Used by the Vite dev server proxy. Defaults to http://localhost:8081.
VITE_DEV_BACKEND=http://localhost:8081

# In production builds, set this to the deployed backend URL (must be the
# same eTLD+1 as the frontend, OR be configured with PORTAL_CORS_ORIGINS on
# the backend so cookies can flow cross-origin).
# Leave blank in dev — the Vite proxy handles same-origin /api calls.
VITE_API_BASE=
